# ─────────────────────────────────────────────────────────────
# Tawabeer — Environment variables template
# Copy to .env.local for local dev, and set the same keys in Vercel.
# Never commit real secrets. Generate fresh values for production.
# ─────────────────────────────────────────────────────────────

# Session signing key (REQUIRED). Generate: openssl rand -base64 48
SESSION_SECRET=

# Admin panel password (REQUIRED for /admin). Use a long random string.
ADMIN_PASSWORD=

# Database — Postgres connection string (REQUIRED).
# Works for both local Postgres and Neon/Vercel.
#   Local example:  postgresql://postgres:postgres@localhost:5432/tawabeer
#   Neon example:   postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=
POSTGRES_URL=

# Browser push notifications (VAPID). Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Telegram bot (optional)
BOT_TOKEN=
# If set, the /api/bot/webhook endpoint requires Telegram's secret_token header.
TELEGRAM_WEBHOOK_SECRET=
